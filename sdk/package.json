{
  "name": "@tx-meta/dcu-sdk",
  "version": "0.2.4",
  "description": "Offchain SDK for DCU Toolkit — ROSCA protocol on Cardano",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tx-meta/dcu-kit"
  },
  "license": "MIT",
  "keywords": [
    "cardano",
    "rosca",
    "blockchain",
    "lucid-evolution",
    "effect",
    "aiken",
    "dcu",
    "coop",
    "chama",
    "sacco",
    "tontine"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --minify --format esm,cjs --dts --clean",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "test": "vitest run",
    "repack": "pnpm run build && pnpm pack",
    "examples:setup": "pnpm run repack && cd examples && pnpm add file:../dcu-sdk-$(node -p 'require(\"../package.json\").version').tgz --force",
    "examples:create-account": "pnpm run examples:setup && cd examples && npx tsx create-account.ts",
    "examples:create-group": "pnpm run examples:setup && cd examples && npx tsx create-group.ts",
    "examples:join-group": "pnpm run examples:setup && cd examples && npx tsx join-group.ts",
    "examples:rosca-lifecycle": "pnpm run examples:setup && cd examples && npx tsx rosca-lifecycle.ts"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@sinclair/typebox": "^0.34.28",
    "@types/node": "^22.13.5",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "libsodium-wrappers": "^0.8.4",
    "libsodium-wrappers-sumo": "^0.8.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "overrides": {
      "libsodium-wrappers-sumo": "0.8.2",
      "libsodium-sumo": "0.8.2"
    }
  },
  "dependencies": {
    "@lucid-evolution/lucid": "0.4.31",
    "@noble/hashes": "^1.8.0",
    "effect": "^3.21.0"
  }
}
