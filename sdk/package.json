{
  "name": "@dcu/sdk",
  "version": "0.1.0",
  "description": "Offchain SDK for DCU Toolkit",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup src/index.ts --minify --format esm,cjs --dts --clean",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@effect/vitest": "^0.17.8",
    "@sinclair/typebox": "^0.34.28",
    "@types/node": "^22.13.5",
    "eslint": "^9.21.0",
    "libsodium-wrappers": "^0.8.2",
    "libsodium-wrappers-sumo": "^0.8.2",
    "prettier": "^3.5.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@lucid-evolution/lucid": "0.4.29",
    "@noble/hashes": "^1.8.0",
    "effect": "^3.14.22"
  }
}
