# --- Network Configuration ---
# Options: Mainnet, Preprod, Preview (Ignored if PROVIDER=Emulator)
NETWORK=Preprod

# --- Provider Selection ---
# Options: Emulator, Maestro, Blockfrost, Kupmios
PROVIDER=Emulator

# --- Blockfrost Provider ---
# Required if PROVIDER=Blockfrost
BLOCKFROST_KEY=
# Optional: Override Blockfrost URL (Default: https://cardano-preprod.blockfrost.io/api/v0)
# Mainnet: https://cardano-mainnet.blockfrost.io/api/v0
# Preprod: https://cardano-preprod.blockfrost.io/api/v0
# Preview: https://cardano-preview.blockfrost.io/api/v0
BLOCKFROST_URL=

# --- Maestro Provider ---
# Required if PROVIDER=Maestro
MAESTRO_API_KEY=

# --- Kupmios Provider (Ogmios + Kupo) ---
# Required if PROVIDER=Kupmios
OGMIOS_URL=
KUPO_URL=

# --- Test Wallets ---
# Required for Live Networks (Preprod/Mainnet)
ADMIN_SEED=
USER1_SEED=
USER2_SEED=
